# ============================================================
# Garmin 同步工具环境变量模板
# 复制此文件为 .env 并填入你的账号信息
# ============================================================

# ---- 佳明中国区账号 ----
GARMIN_USERNAME_DEFAULT=
GARMIN_PASSWORD_DEFAULT=

# ---- 佳明国际区账号 ----
GARMIN_GLOBAL_USERNAME_DEFAULT=
GARMIN_GLOBAL_PASSWORD_DEFAULT=

# ---- 佳明迁移配置（批量迁移历史数据用）----
GARMIN_MIGRATE_NUM_DEFAULT=100
GARMIN_MIGRATE_START_DEFAULT=1

# ---- Bark 推送通知（可选）----
# 从 Bark App 获取你的 Key
BARK_KEY=

# ---- RQ 跑力采集（可选）----
RQ_USERID=
RQ_COOKIE=
RQ_CSRF_TOKEN=

# ---- Google Sheet 数据记录（可选）----
GOOGLE_SHEET_ID=
GOOGLE_API_CLIENT_EMAIL=
GOOGLE_API_PRIVATE_KEY=
